generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Article {
  id             Int       @id @default(autoincrement())
  title          String
  slug           String    @unique
  content        String    @db.LongText
  thumbnailUrl   String?
  authorId       Int
  isPublished    Boolean   @default(false)
  views          Int       @default(0)
  tags           Json?
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  User           User      @relation(fields: [authorId], references: [id])

  @@map("article")
  @@index([authorId])
  @@index([isPublished])
  @@index([publishedAt])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  target    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id])

  @@map("auditlog")
  @@index([userId])
}

model GlobalSetting {
  id                Int      @id @default(autoincrement())
  whatsappNumber    String
  emailContact      String
  officeAddress     String   @db.Text
  instagramLink     String?
  isMaintenanceMode Boolean  @default(false)
  metaPixelId       String?
  googleAnalyticsId String?
  updatedAt         DateTime @updatedAt

  @@map("globalsetting")
}

model Lead {
  id           Int         @id @default(autoincrement())
  name         String
  whatsapp     String
  businessName String?
  message      String?     @db.Text
  status       LeadStatus  @default(NEW)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
  Orders       Order[]

  @@map("lead")
}

model Order {
  id              String         @id @default(uuid())
  leadId          Int
  packageId       Int
  totalAmount     Decimal        @db.Decimal(10, 2)
  briefData       Json
  status          OrderStatus    @default(PENDING_PAYMENT)
  agreedToTermsAt DateTime
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  idempotencyKey  String?        @unique
  handoffUrl      String?
  Lead            Lead           @relation(fields: [leadId], references: [id])
  Package         Package        @relation(fields: [packageId], references: [id])
  Payments        Payment[]
  Project         Project?

  Notes           OrderNote[]
  Resources       OrderResource[]

  @@map("order")
  @@index([leadId])
  @@index([packageId])
  @@index([status])
}

model OrderNote {
  id        Int      @id @default(autoincrement())
  orderId   String
  content   String   @db.Text
  isPublic  Boolean  @default(false)
  isClient  Boolean  @default(false)
  authorId  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isEdited  Boolean  @default(false)
  isDeleted Boolean  @default(false)
  parentId  Int?
  
  Order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  Author    User?    @relation(fields: [authorId], references: [id])
  Parent    OrderNote? @relation("NoteReplies", fields: [parentId], references: [id])
  replies   OrderNote[] @relation("NoteReplies")

  @@map("ordernote")
  @@index([orderId])
  @@index([authorId])
  @@index([parentId])
}

model OrderResource {
  id        Int      @id @default(autoincrement())
  orderId   String
  title     String
  url       String
  icon      String?  // e.g., 'figma', 'gdrive', 'github'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("orderresource")
  @@index([orderId])
}

model Package {
  id            Int       @id @default(autoincrement())
  name          String
  slug          String    @unique
  price         Decimal   @db.Decimal(10, 2)
  discountPrice Decimal?  @db.Decimal(10, 2)
  features      Json
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  Orders        Order[]
  Promos        Promo[]

  @@map("package")
  @@index([isActive])
  @@index([sortOrder])
}

model Payment {
  id              String         @id @default(uuid())
  orderId         String
  paymentMethod   String
  paymentStatus   PaymentStatus  @default(UNPAID)
  paymentProofUrl String?
  paidAt          DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  Order           Order          @relation(fields: [orderId], references: [id])

  @@map("payment")
  @@index([orderId])
}

model Project {
  id                Int                     @id @default(autoincrement())
  orderId           String?                 @unique
  title             String
  slug              String                  @unique
  clientName        String
  category          ProjectCategory
  thumbnailUrl      String?
  description       String                  @db.Text
  techStack         Json
  duration          String
  testimonialQuote  String?                 @db.Text
  testimonialAuthor String?
  maintenanceStatus ProjectMaintenanceStatus @default(CLIENT_MANAGED)
  domainExpiryDate  DateTime?
  seoTitle          String?
  seoDescription    String?
  viewsCount        Int                     @default(0)
  isFeatured        Boolean                 @default(false)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  deletedAt         DateTime?
  Order             Order?                  @relation(fields: [orderId], references: [id])
  Images            ProjectImage[]
  Hosting           Hosting?

  @@map("project")
  @@index([category])
}

model Hosting {
  id                Int            @id @default(autoincrement())
  domain            String         @unique
  clientName        String
  clientWhatsapp    String
  clientEmail       String?
  hostingProvider   String
  hostingStartDate  DateTime
  hostingEndDate    DateTime
  domainEndDate     DateTime?
  notifyBeforeDays  Int            @default(30)
  status            HostingStatus  @default(ACTIVE)
  notes             String?        @db.Text
  projectId         Int?           @unique
  lastNotifiedAt    DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?
  Project           Project?       @relation(fields: [projectId], references: [id])

  @@map("hosting")
  @@index([status])
  @@index([hostingEndDate])
}

model ProjectImage {
  id        Int       @id @default(autoincrement())
  projectId Int
  imageUrl  String
  caption   String?
  sortOrder Int       @default(0)
  deletedAt DateTime?
  Project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("projectimage")
  @@index([projectId])
}

model Promo {
  id        Int       @id @default(autoincrement())
  text      String
  linkUrl   String?
  packageId Int?
  isActive  Boolean   @default(false)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  Package   Package?  @relation(fields: [packageId], references: [id])

  @@map("promo")
  @@index([packageId])
}

model User {
  id           Int        @id @default(autoincrement())
  username     String     @unique
  email        String     @unique
  passwordHash String
  role         UserRole   @default(EDITOR)
  tokenVersion Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  Articles     Article[]
  AuditLogs    AuditLog[]
  OrderNotes   OrderNote[]

  @@map("user")
}

enum PaymentStatus {
  UNPAID
  PAID
  FAILED
  REFUNDED
}

enum ProjectCategory {
  PLATFORM
  E_COMMERCE
  LANDING
  SAAS
  CUSTOM
  SERVICES
  FNB
  RETAIL
  CORPORATE
}

enum UserRole {
  SUPERADMIN
  EDITOR
}

enum LeadStatus {
  NEW
  CONTACTED
  CLOSED_WON
  CLOSED_LOST
}

enum OrderStatus {
  PENDING_PAYMENT
  PROCESSING
  REVISION
  COMPLETED
  CANCELLED
}

enum ProjectMaintenanceStatus {
  ACTIVE
  INACTIVE
  CLIENT_MANAGED
}

enum HostingStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  CANCELLED
}
